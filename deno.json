{
  "name": "@levibostian/decaf-script-conventional-commits",
  "version": "0.1.0",
  "exports": "./script.ts",
  "publish": {
    "include": [
      "README.md",
      "LICENSE",
      "script.ts"
    ]
  },
  "tasks": {
    "test": "deno test --allow-all --junit-path reports/junit.xml --coverage=reports/coverage/",
    "lint": "deno lint --fix",
    "compile": "deno compile --output $OUTPUT_FILE_NAME --allow-env --allow-net --allow-run --allow-read --allow-write --target $DENO_TARGET script.ts"
  },
  "imports": {
    "@levibostian/decaf-sdk": "jsr:@levibostian/decaf-sdk@^0.2.1",
    "@std/assert": "jsr:@std/assert@^1.0.11",
    "@std/semver": "jsr:@std/semver@^1.0.3",
    "conventional-commits-parser": "https://deno.land/x/commit@0.1.2/mod.ts"
  }
}
