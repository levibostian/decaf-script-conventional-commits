{
  "name": "@levibostian/decaf-script-conventional-commits",
  "exports": "./script.ts",
  "publish": {
    "include": [
      "README.md",
      "LICENSE",
      "script.ts"
    ]
  },
  "tasks": {
    "test": "deno test --allow-all --junit-path reports/junit.xml --coverage=reports/coverage/",
    "lint": "deno task format && deno lint --fix",
    "format": "deno fmt"
  },
  "imports": {
    "@levibostian/decaf-sdk": "jsr:@levibostian/decaf-sdk@^0.2.1",
    "@std/assert": "jsr:@std/assert@^1.0.11",
    "@std/semver": "jsr:@std/semver@^1.0.3",
    "conventional-commits-parser": "jsr:@denosaurs/commit@0.1.5"
  },
  "fmt": {
    "lineWidth": 150,
    "semiColons": false,
    "include": ["**/*.ts"],
    "exclude": ["**/*.json", "**/*.md", "**/*.yml", "**/*.yml", "**/*.lock"]
  },
  "lint": {
    "rules": {
      "exclude": ["require-await"]
    }
  },
  "lock": {
    "path": "./deno.lock",
    "frozen": true
  }
}
